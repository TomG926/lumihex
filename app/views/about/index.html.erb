<!-- Hero section -->
<div class="relative isolate overflow-hidden bg-gray-900" data-controller="animation">
  <div class="absolute inset-0">
    <%= image_tag "about-banner.png", alt: "About Banner", class: "h-full w-full object-cover" %>
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 via-gray-900/80 to-gray-900/60"></div>
  </div>
  <div class="relative mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
    <div class="text-center space-y-8">
      <div class="space-y-4">
        <span class="inline-flex items-center rounded-full bg-indigo-600/10 px-3 py-1 text-sm font-semibold leading-6 text-indigo-400 ring-1 ring-inset ring-indigo-600/20" data-animation="scale">
          Our Story
        </span>
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl" data-animation="fade-up">
          Transforming Digital Out-of-Home Advertising
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-300" data-animation="fade-up">
          We're building the future of programmatic DOOH advertising, connecting premium digital screens with innovative advertisers.
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Mission section -->
<div class="bg-white py-32 sm:py-40">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center space-y-8">
      <h2 class="text-base font-semibold leading-7 text-indigo-600" data-animation="fade-up">Our Mission</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl" data-animation="fade-up">Revolutionizing DOOH Advertising</p>
      <p class="mt-6 text-lg leading-8 text-gray-600" data-animation="fade-up">
        We're on a mission to make digital out-of-home advertising more accessible, efficient, and impactful through programmatic technology.
      </p>
    </div>
  </div>
</div>

<!-- Values section -->
<div class="bg-gray-50 py-32 sm:py-40">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center space-y-8">
      <h2 class="text-base font-semibold leading-7 text-indigo-600" data-animation="fade-up">Our Values</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl" data-animation="fade-up">What Drives Us</p>
      <p class="mt-6 text-lg leading-8 text-gray-600" data-animation="fade-up">
        Our core values guide everything we do, from product development to customer relationships.
      </p>
    </div>
    <div class="mx-auto mt-20 max-w-2xl sm:mt-24 lg:mt-32 lg:max-w-none">
      <dl class="grid max-w-xl grid-cols-1 gap-x-12 gap-y-16 lg:max-w-none lg:grid-cols-3">
        <div class="feature-item flex flex-col group" data-animation="fade-up">
          <dt class="flex items-center gap-x-4 text-base font-semibold leading-7 text-gray-900">
            <div class="rounded-xl bg-indigo-600 p-3 text-white group-hover:bg-indigo-500 transition-colors duration-200">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            Innovation
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600">
            <p class="flex-auto">Pushing the boundaries of what's possible in DOOH advertising through technology and creativity.</p>
          </dd>
        </div>
        <div class="feature-item flex flex-col group" data-animation="fade-up">
          <dt class="flex items-center gap-x-4 text-base font-semibold leading-7 text-gray-900">
            <div class="rounded-xl bg-indigo-600 p-3 text-white group-hover:bg-indigo-500 transition-colors duration-200">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
              </svg>
            </div>
            Collaboration
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600">
            <p class="flex-auto">Building strong partnerships with screen owners, advertisers, and agencies to drive mutual success.</p>
          </dd>
        </div>
        <div class="feature-item flex flex-col group" data-animation="fade-up">
          <dt class="flex items-center gap-x-4 text-base font-semibold leading-7 text-gray-900">
            <div class="rounded-xl bg-indigo-600 p-3 text-white group-hover:bg-indigo-500 transition-colors duration-200">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" />
              </svg>
            </div>
            Excellence
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600">
            <p class="flex-auto">Delivering exceptional results and service quality in everything we do.</p>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</div>

<!-- Team section -->
<div class="bg-white py-32 sm:py-40">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center space-y-8">
      <h2 class="text-base font-semibold leading-7 text-indigo-600" data-animation="fade-up">Our Team</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl" data-animation="fade-up">Meet the People Behind Our Success</p>
      <p class="mt-6 text-lg leading-8 text-gray-600" data-animation="fade-up">
        A diverse team of experts passionate about transforming the DOOH advertising landscape.
      </p>
    </div>
    <div class="mx-auto mt-20 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:mt-24 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      <div class="group relative" data-animation="fade-up">
        <div class="aspect-[3/2] w-full overflow-hidden rounded-2xl bg-gray-100">
          <div class="h-full w-full bg-gradient-to-br from-indigo-500 to-purple-600 opacity-90"></div>
        </div>
        <h3 class="mt-6 text-lg font-semibold leading-8 text-gray-900">George Dixon</h3>
        <p class="text-base leading-7 text-gray-600">Co-founder</p>
      </div>
      <div class="group relative" data-animation="fade-up">
        <div class="aspect-[3/2] w-full overflow-hidden rounded-2xl bg-gray-100">
          <div class="h-full w-full bg-gradient-to-br from-purple-500 to-indigo-600 opacity-90"></div>
        </div>
        <h3 class="mt-6 text-lg font-semibold leading-8 text-gray-900">Tom Garrett</h3>
        <p class="text-base leading-7 text-gray-600">Co-founder</p>
      </div>
      <div class="group relative" data-animation="fade-up">
        <div class="aspect-[3/2] w-full overflow-hidden rounded-2xl bg-gray-100">
          <div class="h-full w-full bg-gradient-to-br from-indigo-500 to-violet-600 opacity-90"></div>
        </div>
        <h3 class="mt-6 text-lg font-semibold leading-8 text-gray-900">TBC</h3>
        <p class="text-base leading-7 text-gray-600">Head of Partnerships</p>
      </div>
    </div>
  </div>
</div>

<!-- CTA section -->
<div class="relative isolate overflow-hidden bg-gray-900" data-animation="fade-up">
  <div class="mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
    <div class="text-center space-y-8">
      <div class="space-y-4">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">Ready to Join Our Journey?</h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-300">
          Be part of the future of programmatic DOOH advertising. Join our waitlist today.
        </p>
      </div>
      <div class="flex items-center justify-center gap-x-6">
        <a href="#" class="rounded-md bg-indigo-600 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all duration-200 hover:scale-105">
          Join Waitlist
        </a>
        <a href="#" class="text-base font-semibold leading-6 text-white hover:text-gray-300 transition-colors duration-200">
          Learn more <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</div> 