<!-- Hero section -->
<div class="relative isolate overflow-hidden bg-gray-900" data-controller="animation">
  <div class="absolute inset-0">
    <%= image_tag "home-banner.png", alt: "MVP Development Partners", class: "h-full w-full object-cover hero-image" %>
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 via-gray-900/80 to-gray-900/60"></div>
  </div>
  <div class="relative mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
    <div class="text-center space-y-8">
      <div class="space-y-4">
        <span class="inline-flex items-center rounded-full bg-indigo-600/10 px-3 py-1 text-sm font-semibold leading-6 text-indigo-400 ring-1 ring-inset ring-indigo-600/20" data-animation="scale">
          Coming Soon
        </span>
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl" data-animation="fade-up">
          Programmatic Advertising for the Real World
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-300" data-animation="fade-up">
          Join our network of premium digital screens in taxis, stores, coffee shops, and pubs. 
          Reach your audience where they live, work, and play.
        </p>
      </div>
      <div class="flex items-center justify-center gap-x-6">
        <a href="#" class="rounded-md bg-indigo-600 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all duration-200 hover:scale-105" data-animation="fade-up">
          Join Waitlist
        </a>
        <a href="#" class="text-base font-semibold leading-6 text-white hover:text-gray-300 transition-colors duration-200">
          Learn more <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Features section -->
<div class="bg-white py-32 sm:py-40">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center space-y-8">
      <h2 class="text-base font-semibold leading-7 text-indigo-600" data-animation="fade-up">Why Choose Our Network</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl" data-animation="fade-up">Premium Digital Out-of-Home Advertising</p>
      <p class="mt-6 text-lg leading-8 text-gray-600" data-animation="fade-up">
        Our programmatic platform brings digital advertising to physical spaces, making it easier than ever to reach your target audience.
      </p>
    </div>
    <div class="mx-auto mt-20 max-w-2xl sm:mt-24 lg:mt-32 lg:max-w-none">
      <dl class="grid max-w-xl grid-cols-1 gap-x-12 gap-y-16 lg:max-w-none lg:grid-cols-3">
        <div class="feature-item flex flex-col group" data-animation="fade-up">
          <dt class="flex items-center gap-x-4 text-base font-semibold leading-7 text-gray-900">
            <div class="rounded-xl bg-indigo-600 p-3 text-white group-hover:bg-indigo-500 transition-colors duration-200">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            Premium Locations
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600">
            <p class="flex-auto">Strategic placements in high-traffic areas where your audience spends their time.</p>
          </dd>
        </div>
        <div class="feature-item flex flex-col group" data-animation="fade-up">
          <dt class="flex items-center gap-x-4 text-base font-semibold leading-7 text-gray-900">
            <div class="rounded-xl bg-indigo-600 p-3 text-white group-hover:bg-indigo-500 transition-colors duration-200">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
              </svg>
            </div>
            Programmatic Buying
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600">
            <p class="flex-auto">Real-time bidding and automated campaign management for maximum efficiency.</p>
          </dd>
        </div>
        <div class="feature-item flex flex-col group" data-animation="fade-up">
          <dt class="flex items-center gap-x-4 text-base font-semibold leading-7 text-gray-900">
            <div class="rounded-xl bg-indigo-600 p-3 text-white group-hover:bg-indigo-500 transition-colors duration-200">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" />
              </svg>
            </div>
            Measurable Impact
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600">
            <p class="flex-auto">Detailed analytics and reporting to track your campaign's performance.</p>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</div>

<!-- CTA section -->
<div class="relative isolate overflow-hidden bg-gray-900" data-animation="fade-up">
  <div class="mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
    <div class="text-center space-y-8">
      <div class="space-y-4">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">Ready to Transform Your Advertising?</h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-gray-300">
          Join our waitlist to be among the first to access our premium digital out-of-home advertising network.
        </p>
      </div>
      <div class="flex items-center justify-center gap-x-6">
        <a href="#" class="rounded-md bg-indigo-600 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all duration-200 hover:scale-105">
          Join Waitlist
        </a>
        <a href="#" class="text-base font-semibold leading-6 text-white hover:text-gray-300 transition-colors duration-200">
          Learn more <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</div>
